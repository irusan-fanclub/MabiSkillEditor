<Window x:Class="MabiSkillEditor.UI.Windows.WeaponPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="從武器找 tag" Height="540" Width="836"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e2e" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="CanResize"
        BorderBrush="#45475a" BorderThickness="1">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#313244"/>
            <Setter Property="Foreground"  Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="CaretBrush"  Value="#cdd6f4"/>
            <Setter Property="Padding"     Value="6,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#313244"/>
            <Setter Property="Foreground"  Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="Padding"     Value="6,2"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="#181825"/>
            <Setter Property="Foreground"      Value="#cdd6f4"/>
            <Setter Property="BorderBrush"     Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#45475a"/>
                    <Setter Property="Foreground" Value="#cdd6f4"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"      Value="#89b4fa"/>
            <Setter Property="Foreground"      Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="SecondBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ══ 自訂 Titlebar ═══════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#11111b" Height="32"
                BorderBrush="#45475a" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="10,0,0,0" VerticalAlignment="Center">
                    <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="#89b4fa" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Fill="{x:Null}"
                                  Data="M 15 4 V 2 M 15 16 v -2 M 8 9 h 2 M 20 9 h 2 M 17.8 11.8 L 19 13 M 15 9 h .01 M 17.8 6.2 L 19 5 M 3 21 L 12 12 M 12.2 6.2 L 11 5"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="從武器找 tag" Foreground="#cdd6f4"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnMin"   Content="&#xE921;"
                            Style="{StaticResource CaptionBtn}"
                            Click="BtnMin_Click" ToolTip="最小化"/>
                    <Button x:Name="BtnMax"   Content="&#xE922;"
                            Style="{StaticResource CaptionBtn}"
                            Click="BtnMax_Click" ToolTip="最大化"/>
                    <Button x:Name="BtnClose" Content="&#xE8BB;"
                            Style="{StaticResource CloseBtn}"
                            Click="BtnClose_Click" ToolTip="關閉"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ 內容 ════════════════════════════════════ -->
        <DockPanel Margin="12">
        <!-- Filter row -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="類型：" VerticalAlignment="Center" Foreground="#a6adc8"/>
                <ComboBox x:Name="CmbType" Width="140" SelectionChanged="Filter_Changed"/>
                <TextBlock Text="搜尋：" VerticalAlignment="Center" Foreground="#a6adc8" Margin="16,0,0,0"/>
                <TextBox  x:Name="TxtSearch" Width="320" TextChanged="Filter_Changed"/>
                <TextBlock x:Name="TxtMatchCount" VerticalAlignment="Center"
                           Foreground="#6c7086" FontSize="11" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Buttons row -->
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Click="BtnCancel_Click" Style="{StaticResource SecondBtn}" Width="90"/>
                <Button Content="加入" Click="BtnApply_Click"  Margin="8,0,0,0" Width="90"/>
            </StackPanel>
        </Border>

        <!-- 3 columns -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280*" MinWidth="180"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="260*" MinWidth="180"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="260*" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- 武器列表 -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" Background="#181825"
                        BorderBrush="#45475a" BorderThickness="1,1,1,0" Padding="8,4">
                    <TextBlock Text="武器" Foreground="#a6e3a1" FontWeight="SemiBold" FontSize="12"/>
                </Border>
                <ListBox x:Name="WeaponList" SelectionChanged="WeaponList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="10" Foreground="#6c7086"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="#"/><Run Text="{Binding ID, Mode=OneTime}"/>
                                    <Run Text=" · "/><Run Text="{Binding EngName, Mode=OneTime}"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Tags of selected weapon -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top" Background="#181825"
                        BorderBrush="#45475a" BorderThickness="1,1,1,0" Padding="8,4">
                    <TextBlock x:Name="TxtTagsHeader" Text="該武器的 tag"
                               Foreground="#a6e3a1" FontWeight="SemiBold" FontSize="12"/>
                </Border>
                <ListBox x:Name="TagList" SelectionChanged="TagList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          IsEnabled="{Binding IsSelectable}"
                                          Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Display}" FontSize="12"
                                           Foreground="{Binding LabelForeground}"/>
                                <TextBlock Text="{Binding Description}"
                                           Visibility="{Binding DescriptionVisibility}"
                                           Margin="6,0,0,0" FontSize="11"
                                           Foreground="#6c7086"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Weapons containing the selected tag -->
            <DockPanel Grid.Column="4">
                <Border DockPanel.Dock="Top" Background="#181825"
                        BorderBrush="#45475a" BorderThickness="1,1,1,0" Padding="8,4">
                    <TextBlock x:Name="TxtTagWeaponsHeader" Text="含此 tag 的武器（前 15）"
                               Foreground="#a6e3a1" FontWeight="SemiBold" FontSize="12"/>
                </Border>
                <Grid>
                    <ListBox x:Name="TagWeaponList">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="TxtTagWeaponsHint"
                               Text="點左側 tag 看哪些武器有"
                               Foreground="#6c7086" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>
            </DockPanel>
        </Grid>
        </DockPanel>
    </DockPanel>
</Window>
