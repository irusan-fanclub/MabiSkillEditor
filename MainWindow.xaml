<Window x:Class="MabiSkillEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="MabiSkillEditor" Height="800" Width="1280"
        Background="#1e1e2e" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="CanResize"
        BorderBrush="#45475a" BorderThickness="1"
        Icon="app.ico">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#313244"/>
            <Setter Property="Foreground"   Value="#cdd6f4"/>
            <Setter Property="BorderBrush"  Value="#45475a"/>
            <Setter Property="CaretBrush"   Value="#cdd6f4"/>
            <Setter Property="Padding"      Value="6,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"      Value="#89b4fa"/>
            <Setter Property="Foreground"      Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#f38ba8"/>
        </Style>
        <Style x:Key="SecondBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="#181825"/>
            <Setter Property="Foreground"               Value="#cdd6f4"/>
            <Setter Property="BorderBrush"              Value="#45475a"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="RowBackground"            Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1e1e2e"/>
            <Setter Property="ColumnHeaderHeight"       Value="28"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"       Value="#313244"/>
            <Setter Property="Foreground"       Value="#89b4fa"/>
            <Setter Property="Padding"          Value="8,0"/>
            <Setter Property="BorderBrush"      Value="#45475a"/>
            <Setter Property="BorderThickness"  Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#45475a"/>
                    <Setter Property="Foreground" Value="#cdd6f4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── TabControl 樣式（兩個主分頁） ── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"      Value="#1e1e2e"/>
            <Setter Property="BorderBrush"     Value="#45475a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Foreground" Value="#a6adc8"/>
            <Setter Property="Padding"    Value="16,7"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Margin"     Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="12"
                                              TextBlock.FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#89b4fa"/>
                                <Setter Property="Foreground" Value="#89b4fa"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"  Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#cdd6f4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
    <DockPanel>

        <!-- ══ 自訂 Titlebar ═══════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#11111b" Height="32"
                BorderBrush="#45475a" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左：圖示 + 標題 + 版本（雙擊 = 最大化／還原；可拖曳） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="10,0,0,0" VerticalAlignment="Center">
                    <!-- Lucide wand icon (ISC license) -->
                    <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="#89b4fa" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Fill="{x:Null}"
                                  Data="M 15 4 V 2 M 15 16 v -2 M 8 9 h 2 M 20 9 h 2 M 17.8 11.8 L 19 13 M 15 9 h .01 M 17.8 6.2 L 19 5 M 3 21 L 12 12 M 12.2 6.2 L 11 5"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="MabiSkillEditor" Foreground="#cdd6f4"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleVersion" Text="" Foreground="#6c7086"
                               FontSize="11" Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 右：min / max / close -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnMin"   Content="&#xE921;"
                            Style="{StaticResource CaptionBtn}"
                            Click="BtnMin_Click" ToolTip="最小化"/>
                    <Button x:Name="BtnMax"   Content="&#xE922;"
                            Style="{StaticResource CaptionBtn}"
                            Click="BtnMax_Click" ToolTip="最大化"/>
                    <Button x:Name="BtnClose" Content="&#xE8BB;"
                            Style="{StaticResource CloseBtn}"
                            Click="BtnClose_Click" ToolTip="關閉"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ 工具列 ══════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#181825"
                BorderBrush="#45475a" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="遊戲資料夾：" VerticalAlignment="Center" Foreground="#a6adc8"/>
                <TextBox x:Name="TxtGameFolder" Width="260"/>
                <Button Content="瀏覽" Click="BtnBrowse_Click" Margin="4,0,0,0"
                        Style="{StaticResource SecondBtn}"/>
                <Button x:Name="BtnLoad" Content="載入" Click="BtnLoad_Click" Margin="8,0,16,0"/>

                <TextBlock Text=".it 檔名：" VerticalAlignment="Center" Foreground="#a6adc8"/>
                <TextBox x:Name="TxtItName" Width="160"/>
                <TextBlock Text="_0.it" VerticalAlignment="Center" Margin="4,0,16,0"
                           Foreground="#a6adc8"/>
                <Button x:Name="BtnExport" Content="輸出" Click="BtnExport_Click"
                        Background="#a6e3a1" Foreground="#1e1e2e"/>
                <Button x:Name="BtnLoadDiff" Content="載入修改記錄" Click="BtnLoadDiff_Click"
                        Margin="8,0,0,0" Style="{StaticResource SecondBtn}"/>

                <TextBlock x:Name="TxtStatus" Margin="16,0,0,0" VerticalAlignment="Center"
                           Foreground="#a6adc8" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ══ 主分頁 ══════════════════════════════════ -->
        <TabControl Background="#1e1e2e" BorderThickness="0">

        <!-- ─ 分頁 1：技能編輯（原本的三欄主體）─ -->
        <TabItem Header="技能編輯">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="180"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"   MinWidth="240"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="340" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- ─ 左欄：技能清單 ─ -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" Background="#181825"
                        BorderBrush="#45475a" BorderThickness="0,0,0,1" Padding="8,6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="搜尋：" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtSearch" Width="200"
                                     TextChanged="TxtSearch_TextChanged"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkShowMonster"
                                  Content="顯示怪物/寵物技能"
                                  Margin="0,6,0,0"
                                  Checked="ChkShowMonster_Changed"
                                  Unchecked="ChkShowMonster_Changed"/>
                    </StackPanel>
                </Border>
                <DataGrid x:Name="SkillGrid"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" CanUserResizeRows="False"
                          SelectionChanged="SkillGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"    Binding="{Binding SkillID}"    Width="55"/>
                        <DataGridTextColumn Header="名稱"  Binding="{Binding DisplayName}" Width="*"/>
                        <DataGridTextColumn Header="英文名" Binding="{Binding EngName}"    Width="110"/>
                        <DataGridTemplateColumn Header="行號" Width="52">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LineNumber}" TextAlignment="Center" Foreground="#585b70"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#313244"/>

            <!-- ─ 中欄：原始區塊 ─ -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top" Background="#181825"
                        BorderBrush="#45475a" BorderThickness="0,0,0,1" Padding="12,8">
                    <TextBlock Text="原始資料" Foreground="#89b4fa"
                               FontWeight="SemiBold" FontSize="13"/>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <StackPanel>
                        <TextBlock x:Name="OTitle" Text="請選擇一個技能"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#cdd6f4" Margin="0,0,0,16"/>

                        <TextBlock Text="基本" Foreground="#a6e3a1"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition MinHeight="24"/>
                                <RowDefinition MinHeight="24"/>
                                <RowDefinition MinHeight="24"/>
                                <RowDefinition MinHeight="24"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="SkillID"   Grid.Row="0" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OID"     Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="英文名"    Grid.Row="1" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OEng"    Grid.Row="1" Grid.Column="1"/>
                            <TextBlock Text="IsHidden"      Grid.Row="2" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OHidden"     Grid.Row="2" Grid.Column="1" Foreground="#f38ba8"/>
                            <TextBlock Text="AvailableRace" Grid.Row="3" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OAvailRace"  Grid.Row="3" Grid.Column="1" Foreground="#89dceb"/>
                        </Grid>

                        <TextBlock Text="分類" Foreground="#a6e3a1"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition MinHeight="24"/>
                                <RowDefinition MinHeight="24"/>
                                <RowDefinition MinHeight="24"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="SkillType"     Grid.Row="0" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OSkillType"  Grid.Row="0" Grid.Column="1" Foreground="#89dceb"/>
                            <TextBlock Text="TriggerType"   Grid.Row="1" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OTriggerType" Grid.Row="1" Grid.Column="1" Foreground="#89dceb"/>
                            <TextBlock Text="SkillCategory" Grid.Row="2" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OSkillCategory" Grid.Row="2" Grid.Column="1"
                                       Foreground="#89dceb" TextWrapping="Wrap"/>
                        </Grid>

                        <TextBlock Text="武器 / 使用對象" Foreground="#a6e3a1"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition MinHeight="24"/>
                                <RowDefinition MinHeight="24"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="WeaponStringID"   Grid.Row="0" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OWeapon"        Grid.Row="0" Grid.Column="1"
                                       Foreground="#fab387" TextWrapping="Wrap"/>
                            <TextBlock Text="TargetPreference" Grid.Row="1" Grid.Column="0" Foreground="#a6adc8"/>
                            <TextBlock x:Name="OTarget"        Grid.Row="1" Grid.Column="1" Foreground="#fab387"/>
                        </Grid>

                        <TextBlock Text="職業 / 天賦（有值）" Foreground="#a6e3a1"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="OTalents">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#313244" CornerRadius="4"
                                            Margin="0,0,6,6" Padding="7,3">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Key}"   FontSize="11"/>
                                            <TextBlock Text="{Binding Value}" FontSize="11"
                                                       Foreground="#a6e3a1" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="#313244"/>

            <!-- ─ 右欄：編輯區塊 ─ -->
            <DockPanel Grid.Column="4">
                <Border DockPanel.Dock="Top" Background="#181825"
                        BorderBrush="#45475a" BorderThickness="0,0,0,1" Padding="12,8">
                    <TextBlock Text="編輯" Foreground="#a6e3a1"
                               FontWeight="SemiBold" FontSize="13"/>
                </Border>

                <!-- 上半：已修改技能列表 -->
                <DockPanel DockPanel.Dock="Top" Height="200">
                    <Border DockPanel.Dock="Top" Padding="8,4" Background="#181825"
                            BorderBrush="#45475a" BorderThickness="0,0,0,1">
                        <TextBlock Text="已修改的技能" Foreground="#a6adc8" FontSize="11"/>
                    </Border>
                    <DataGrid x:Name="ModifiedGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserResizeRows="False"
                              SelectionChanged="ModifiedGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"   Binding="{Binding Original.SkillID}"    Width="55"/>
                            <DataGridTextColumn Header="名稱" Binding="{Binding Original.DisplayName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <Border BorderBrush="#45475a" BorderThickness="0,1,0,0">
                <!-- 下半：編輯表單 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <StackPanel>
                        <TextBlock x:Name="ETitle" Text="選擇技能後在此編輯"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#cdd6f4" Margin="0,0,0,14"/>

                        <!-- ── 武器條件 ── -->
                        <TextBlock Text="武器條件（WeaponStringID）" Foreground="#a6adc8" Margin="0,0,0,6"/>

                        <!-- 持握方式 -->
                        <TextBlock Text="持握方式（擇一）" Foreground="#585b70" FontSize="11" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="RHandNone"   Content="不限"  GroupName="HandType"
                                         IsChecked="True" Checked="HandType_Checked" Margin="0,0,12,0"/>
                            <RadioButton x:Name="RHandSingle" Content="單手 /righthand/" GroupName="HandType"
                                         Checked="HandType_Checked" Margin="0,0,12,0"/>
                            <RadioButton x:Name="RHandDouble" Content="雙手 /twohand/"   GroupName="HandType"
                                         Checked="HandType_Checked"/>
                        </StackPanel>

                        <!-- 武器種類 -->
                        <TextBlock Text="武器種類（可複選，以 | 連接）" Foreground="#585b70" FontSize="11" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="EWeaponList" Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              Foreground="#cdd6f4" Margin="0,0,10,5"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 自訂條件 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="自訂條件（以 | 附加在最後）" Grid.Column="0"
                                       Foreground="#585b70" FontSize="11" VerticalAlignment="Center"/>
                            <Button x:Name="BtnWeaponPicker" Content="+ 從武器找 tag"
                                    Grid.Column="1" Style="{StaticResource SecondBtn}"
                                    FontSize="11" Padding="6,2"
                                    Click="BtnWeaponPicker_Click"
                                    ToolTip="從遊戲武器資料挑 tag 加入自訂條件"/>
                        </Grid>
                        <TextBox x:Name="EWeaponCustom" Margin="0,0,0,8"
                                 TextChanged="EWeaponCustom_TextChanged"
                                 ToolTip="可填入任意 tag，例如 /staff/ | /wand/"/>

                        <!-- 預覽 -->
                        <TextBlock Text="預覽" Foreground="#585b70" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="EWeaponPreview" IsReadOnly="True"
                                 Background="#1e1e2e" Foreground="#a6e3a1"
                                 TextWrapping="Wrap" Margin="0,0,0,2"/>
                        <TextBlock Text="預覽空白 = 套用時刪除此屬性" Foreground="#585b70"
                                   FontSize="10" Margin="0,0,0,14"/>

                        <TextBlock Text="TargetPreference" Foreground="#a6adc8" Margin="0,0,0,4"/>
                        <TextBox x:Name="ETarget" Margin="0,0,0,14"/>

                        <!-- 進階：分類欄位（暫時停用，下版本啟用）
                        <ToggleButton x:Name="EAdvancedToggle"
                                      Content="進階：分類欄位"
                                      Background="Transparent" Foreground="#a6adc8"
                                      BorderThickness="0" HorizontalAlignment="Left"
                                      Cursor="Hand" Padding="0" Margin="0,0,0,6"
                                      Checked="EAdvancedToggle_Changed"
                                      Unchecked="EAdvancedToggle_Changed"/>
                        <StackPanel x:Name="EAdvancedPanel" Visibility="Collapsed" Margin="0,0,0,14">
                            <TextBlock Text="SkillType" Foreground="#a6adc8" Margin="0,0,0,4"/>
                            <TextBox x:Name="ESkillType" Margin="0,0,0,8"/>
                            <TextBlock Text="TriggerType" Foreground="#a6adc8" Margin="0,0,0,4"/>
                            <TextBox x:Name="ETriggerType" Margin="0,0,0,8"/>
                            <TextBlock Text="SkillCategory" Foreground="#a6adc8" Margin="0,0,0,4"/>
                            <TextBox x:Name="ESkillCategory" Margin="0,0,0,4"/>
                            <TextBlock Text="留空 = 套用時刪除此屬性"
                                       Foreground="#585b70" FontSize="10"/>
                        </StackPanel>
                        -->

                        <StackPanel Orientation="Horizontal">
                            <Button Content="套用修改" Click="BtnCommit_Click" Width="90"/>
                            <Button Content="還原原始" Click="BtnRevert_Click" Width="90"
                                    Margin="8,0,0,0" Style="{StaticResource DangerBtn}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                </Border>
            </DockPanel>
        </Grid>
        </TabItem>

        <!-- ─ 分頁 2：快速範本 ─ -->
        <TabItem Header="快速範本">
            <DockPanel Background="#1e1e2e">
                <Border DockPanel.Dock="Top" Background="#181825"
                        BorderBrush="#45475a" BorderThickness="0,0,0,1" Padding="12,8">
                    <TextBlock Text="點「套用」會把範本記錄加入「已修改」清單，可在「技能編輯」分頁檢視 / 還原"
                               Foreground="#a6adc8" FontSize="12"/>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <ItemsControl x:Name="PresetList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#313244" CornerRadius="6"
                                        BorderBrush="#45475a" BorderThickness="1"
                                        Padding="14,10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#cdd6f4"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SkillIDLabel}"
                                                       Foreground="#a6adc8"
                                                       FontSize="11" Margin="0,2,0,6"/>
                                            <ItemsControl ItemsSource="{Binding Changes}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   Foreground="#fab387"
                                                                   FontSize="11"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,1,0,1"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <Button Grid.Column="1" VerticalAlignment="Center"
                                                Content="{Binding StatusLabel}"
                                                IsEnabled="{Binding CanApply}"
                                                Tag="{Binding}"
                                                Click="BtnApplyPreset_Click"
                                                MinWidth="120" Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        </TabControl>
    </DockPanel>

    <!-- ══ 載入中 Overlay ══════════════════════════════ -->
    <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Background="#BB1e1e2e">
        <Border Background="#313244" CornerRadius="10"
                Padding="36,22" HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#45475a" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="LoadingText" Text="載入中..."
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#cdd6f4" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>

    <!-- ══ 結果 Overlay（輸出完成）══════════════════════ -->
    <Grid x:Name="ResultOverlay" Visibility="Collapsed" Background="#BB1e1e2e"
          MouseLeftButtonDown="ResultOverlay_Backdrop_Click">
        <Border Background="#313244" CornerRadius="10"
                Padding="32,22" HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#45475a" BorderThickness="1" MaxWidth="640"
                MouseLeftButtonDown="ResultOverlay_Inner_Click">
            <StackPanel>
                <TextBlock x:Name="ResultTitle" Text="輸出完成"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#a6e3a1" TextAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock x:Name="ResultMessage" Text=""
                           Foreground="#cdd6f4" TextAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,0,14"/>
                <TextBlock Text="輸出路徑" Foreground="#a6adc8"
                           FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="ResultPath" IsReadOnly="True"
                         Background="#1e1e2e" Foreground="#fab387"
                         BorderBrush="#45475a"
                         TextWrapping="Wrap" MinWidth="460" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="複製路徑" Click="BtnCopyPath_Click" Width="100"/>
                    <Button Content="複製到 package" Click="BtnCopyToPackage_Click"
                            Width="120" Margin="8,0,0,0"
                            Background="#a6e3a1" Foreground="#1e1e2e"/>
                    <Button Content="開啟資料夾" Click="BtnOpenFolder_Click"
                            Width="100" Margin="8,0,0,0"
                            Style="{StaticResource SecondBtn}"/>
                </StackPanel>
                <TextBlock x:Name="ResultCopyStatus" Text=""
                           Foreground="#a6e3a1" FontSize="11"
                           TextAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="點擊外部關閉" Foreground="#585b70"
                           FontSize="10" TextAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>

    </Grid>
</Window>
